    "@pulo/farcaster": "workspace:*",
    "@pulo/safety": "workspace:*",
    "@pulo/db": "workspace:*",
    "@pulo/truth": "workspace:*",
    "@pulo/radar": "workspace:*",
    "@pulo/auth": "workspace:*",
    "@pulo/billing": "workspace:*",
    "@pulo/composer": "workspace:*",
    "@pulo/errors": "workspace:*",
    "zod": "^3.24.2",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
