  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --outDir dist --declaration",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^5.2.1",
