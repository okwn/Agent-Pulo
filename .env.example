# Environment Variables

# ─── Application ─────────────────────────────────────────────
APP_NAME=PULO
NODE_ENV=development
LOG_LEVEL=info

# ─── Ports (see docs/deployment/LOCAL_PORT_STRATEGY.md) ───────
# WEB_PORT=4310   # resolved at startup via find-free-port.mjs
# API_PORT=4311   # resolved at startup via find-free-port.mjs
# WORKER_HEALTH_PORT=4312
# DB_PORT=5544
# REDIS_PORT=6388

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5544/pulo"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6388"

# ─── LLM / AI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Neynar / Warpcast / Fid ──────────────────────────────────
NEYNAR_API_KEY=...
NEYNAR_SIGNER_SECRET=...
FARCASTER_NEYNAR_API_KEY=...
FID=
DEVELOPER_FID=
VERIFIED_WALLETS=

# ─── Pulo Agent ───────────────────────────────────────────────
PULO_AGENT_ID=
PULO_SIGNER_UUID=
PULO_FARCASTER_Signer_UUID=
PULO_ADMIN_FIDS=

# ─── Feature Flags ────────────────────────────────────────────
ENABLE_TRUTH_ANALYSIS=true
ENABLE_TREND_RADAR=true
ENABLE_REWARD_DETECTION=true
ENABLE_AIRDROP_ALERTS=true
ENABLE_GRANT_ALERTS=true

# ─── Safety & Limits ──────────────────────────────────────────
MAX_CASTS_PER_USER_PER_DAY=50
MAX_DMS_PER_USER_PER_DAY=10
RATE_LIMIT_PER_MINUTE=30
ALLOWED_CHANNELS=
BLOCKED_USERS=

# ─── Observability ────────────────────────────────────────────
LOGDNA_KEY=
SENTRY_DSN=