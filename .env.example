# PULO Environment Variables
# ─── Modes ────────────────────────────────────────────────────────────
# Independent modes — each provider can be set independently
# mock = works with zero external keys
# live/stripe/etc = requires mode-specific keys
PULO_APP_ENV=local                    # local | staging | production
PULO_FARCASTER_MODE=mock             # mock | live
PULO_LLM_MODE=mock                   # mock | openai | anthropic | local
PULO_SEARCH_MODE=mock                # mock | tavily | serpapi | disabled
PULO_NOTIFICATION_MODE=mock         # mock | live
PULO_BILLING_MODE=mock               # mock | stripe | hypersub | disabled
PULO_AUTH_MODE=demo                 # demo | farcaster | disabled

# ─── Database & Redis ────────────────────────────────────────────────
DATABASE_URL=postgresql://pulo:pulo_dev_password@localhost:5432/pulo_dev
REDIS_URL=redis://localhost:6379

# ─── Ports ─────────────────────────────────────────────────────────────
PULO_WEB_PORT=4310
PULO_API_PORT=4311
PULO_WORKER_PORT=4312
PULO_POSTGRES_PORT=5432
PULO_REDIS_PORT=6379

# ─── App ─────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PULO_SERVICE_NAME=pulo

# ─── Neynar / Far caster ───────────────────────────────────────────────
# Required for PULO_FARCASTER_MODE=live
NEYNAR_API_KEY=
NEYNAR_WEBHOOK_SECRET=
FARCASTER_BOT_FID=
FARCASTER_BOT_SIGNER_UUID=
FARCASTER_NEYNAR_API_KEY=

# ─── LLM Providers ──────────────────────────────────────────────────────
# Required for PULO_LLM_MODE=openai
OPENAI_API_KEY=
# Required for PULO_LLM_MODE=anthropic
ANTHROPIC_API_KEY=
# Required for PULO_LLM_MODE=local
LOCAL_LLM_URL=http://localhost:11434

# ─── Search ─────────────────────────────────────────────────────────────
# Required for PULO_SEARCH_MODE=tavily
TAVILY_API_KEY=
# Required for PULO_SEARCH_MODE=serpapi
SERPAPI_API_KEY=

# ─── Billing ────────────────────────────────────────────────────────────
# Required for PULO_BILLING_MODE=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Feature Flags ─────────────────────────────────────────────────────
ENABLE_TRUTH_ANALYSIS=true
ENABLE_TREND_RADAR=true
ENABLE_REWARD_DETECTION=true
ENABLE_AIRDROP_ALERTS=true
ENABLE_GRANT_ALERTS=true

# ─── Safety & Limits ─────────────────────────────────────────────────────
MAX_CASTS_PER_USER_PER_DAY=50
MAX_DMS_PER_USER_PER_DAY=10
RATE_LIMIT_PER_MINUTE=30

# ─── Observability ──────────────────────────────────────────────────────
SENTRY_DSN=
LOGDNA_KEY=